<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="actionModeStyle">@style/Widget.App.ActionMode</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="colorControlNormal">@color/colorAccent</item>
    </style>


    <style name="Widget.App.ActionMode" parent="Widget.AppCompat.ActionMode">
        <item name="titleTextStyle">?attr/textAppearanceHeadline6</item>
        <item name="subtitleTextStyle">?attr/textAppearanceSubtitle1</item>
        <item name="background">@color/colorRedOpacity</item>
    </style>

    <!-- ******************************************************************* -->

    <!-- Texto com Sombra -->
    <style name="radius">
        <item name="android:shadowColor">@android:color/black</item>
        <item name="android:shadowRadius">3</item>
        <item name="android:shadowDx">2</item>
        <item name="android:shadowDy">2</item>
    </style>
    <style name="radius1">
        <item name="android:shadowColor">@color/colorItemShadow</item>
        <item name="android:shadowRadius">3</item>
        <item name="android:shadowDx">2</item>
        <item name="android:shadowDy">2</item>
    </style>
    <style name="viewText" parent="radius">
        <item name="android:textColor">@color/colorText</item>
    </style>

    <style name="progress" parent="radius">
        <item name="android:textColor">@color/colorText</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="item" parent="radius1">
        <item name="android:textColor">@color/colorItemText</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="detailName" parent="radius">
        <item name="android:textColor">@color/colorText</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="detailTile" parent="radius">
        <item name="android:textColor">@color/colorText</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="detailText" parent="radius">
        <item name="android:textColor">@color/colorText</item>
        <item name="android:textSize">10sp</item>
    </style>
</resources>
